  <!-- Scripts -->
  <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
  <script>
    // ============================================
    // POSTAL - MAIN APPLICATION JAVASCRIPT
    // ============================================
    
    // Global State
    let peer = null;
    let conn = null;
    let peers = {}; // For group chat
    let myPeerId = null;
    let isPaid = false;
    let messageCount = 0;
    let freeMessages = 15;
    let encryptionKey = null;
    let vanishMode = false;
    let autoDestructTimer = 0;
    let isRecording = false;
    let mediaRecorder = null;
    let audioChunks = [];
    let recordingDuration = 0;
    let typingTimeout = null;
    let soundEnabled = true;
    let selectedPlan = 'lifetime';
    let escapeCount = 0;
    let escapeTimer = null;
    
    // Initialize app
    document.addEventListener('DOMContentLoaded', () => {
      initApp();
    });
    
    async function initApp() {
      // Check for terms acceptance
      if (!sessionStorage.getItem('postal_terms_accepted')) {
        showOverlay('terms');
      }
      
      // Load saved settings
      loadSettings();
      
      // Initialize PeerJS
      initPeer();
      
      // Check for URL params
      checkUrlParams();
      
      // Setup event listeners
      setupEventListeners();
      
      // Register service worker
      registerServiceWorker();
    }
    
    function loadSettings() {
      const savedTheme = localStorage.getItem('postal_theme') || 'void';
      setTheme(savedTheme);
      
      isPaid = localStorage.getItem('postal_paid') === 'true';
      messageCount = parseInt(localStorage.getItem('postal_message_count') || '0');
      freeMessages = parseInt(localStorage.getItem('postal_free_messages') || '15');
      soundEnabled = localStorage.getItem('postal_sound') !== 'false';
      vanishMode = localStorage.getItem('postal_vanish') === 'true';
      
      updatePremiumUI();
      
      if (!soundEnabled) {
        document.getElementById('soundToggle').classList.remove('active');
      }
      
      if (vanishMode) {
        document.getElementById('vanishToggle').classList.add('active');
        document.getElementById('settingsVanishToggle').classList.add('active');
      }
    }
    
    function initPeer() {
      const peerId = 'POSTAL-' + Math.random().toString(36).substr(2, 9).toUpperCase();
      
      peer = new Peer(peerId, {
        debug: 0
      });
      
      peer.on('open', (id) => {
        myPeerId = id;
        updateNodeIdDisplay();
        updateStatus('offline');
        generateQRCode();
      });
      
      peer.on('connection', (connection) => {
        handleIncomingConnection(connection);
      });
      
      peer.on('error', (err) => {
        console.error('PeerJS error:', err);
        showToast('Connection error: ' + err.type);
      });
    }
    
    function handleIncomingConnection(connection) {
      conn = connection;
      setupConnection(conn);
      updateStatus('connected');
      addSystemMessage('Peer connected: ' + conn.peer.substring(0, 12) + '...');
    }
    
    function setupConnection(connection) {
      connection.on('open', () => {
        updateStatus('connected');
      });
      
      connection.on('data', (data) => {
        handleIncomingData(data, connection);
      });
      
      connection.on('close', () => {
        updateStatus('offline');
        addSystemMessage('Peer disconnected');
        conn = null;
      });
    }
    
    function handleIncomingData(data, connection) {
      switch (data.type) {
        case 'MSG':
          handleIncomingMessage(data, connection);
          break;
        case 'CMD_TYPING_START':
          showTypingIndicator();
          break;
        case 'CMD_TYPING_STOP':
          hideTypingIndicator();
          break;
        case 'CMD_SEEN':
          markMessageSeen(data.msgId);
          break;
        case 'CMD_REACT':
          addReaction(data.msgId, data.emoji);
          break;
        case 'CMD_PURGE':
          purgeChat();
          break;
        case 'VOICE':
          handleVoiceNote(data);
          break;
        case 'FILE':
          handleFile(data);
          break;
        case 'PEER_LIST':
          handlePeerList(data.peers);
          break;
        default:
          console.log('Unknown message type:', data.type);
      }
    }
    
    function handleIncomingMessage(data, connection) {
      let content = data.content;
      
      // Decrypt if encryption is enabled
      if (encryptionKey && data.encrypted) {
        content = decryptMessage(content, encryptionKey);
      }
      
      addMessage(content, 'peer', data.id, data.timestamp);
      notifyUser('New message', content.substring(0, 50));
      
      // Send seen receipt
      if (conn && conn.open) {
        conn.send({ type: 'CMD_SEEN', msgId: data.id });
      }
      
      // Handle vanish mode
      if (vanishMode) {
        setTimeout(() => {
          deleteMessage(data.id);
        }, 60000);
      }
    }
    
    function connectToPeer() {
      const peerId = document.getElementById('peerIdInput').value.trim();
      const password = document.getElementById('sessionPassword').value;
      
      if (!peerId) {
        showToast('Please enter a Peer ID');
        return;
      }
      
      // Setup encryption if password provided
      if (password) {
        setupEncryption(password);
      }
      
      conn = peer.connect(peerId, { reliable: true });
      
      conn.on('open', () => {
        setupConnection(conn);
        updateStatus('connected');
        addSystemMessage('Connected to peer: ' + peerId.substring(0, 12) + '...');
        hideOverlay('connect');
      });
      
      conn.on('error', (err) => {
        showToast('Failed to connect: ' + err);
      });
    }
    
    function setupEventListeners() {
      // Message input
      const messageInput = document.getElementById('messageInput');
      messageInput.addEventListener('input', () => {
        messageInput.style.height = 'auto';
        messageInput.style.height = messageInput.scrollHeight + 'px';
        document.getElementById('sendBtn').disabled = !messageInput.value.trim() && !conn;
        
        // Send typing indicator
        if (conn && conn.open) {
          conn.send({ type: 'CMD_TYPING_START' });
          clearTimeout(typingTimeout);
          typingTimeout = setTimeout(() => {
            if (conn && conn.open) {
              conn.send({ type: 'CMD_TYPING_STOP' });
            }
          }, 2000);
        }
      });
      
      messageInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          sendMessage();
        }
      });
      
      // Privacy blur
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          document.getElementById('privacyBlur').classList.add('visible');
        } else {
          document.getElementById('privacyBlur').classList.remove('visible');
        }
      });
      
      window.addEventListener('blur', () => {
        document.getElementById('privacyBlur').classList.add('visible');
      });
      
      window.addEventListener('focus', () => {
        document.getElementById('privacyBlur').classList.remove('visible');
      });
      
      // Screenshot prevention
      document.addEventListener('keydown', (e) => {
        // PrtSc
        if (e.key === 'PrintScreen') {
          navigator.clipboard.writeText('');
          showToast('Screenshot blocked');
        }
        
        // Cmd+Shift+3/4/5 (Mac)
        if ((e.metaKey || e.ctrlKey) && e.shiftKey && ['3', '4', '5'].includes(e.key)) {
          e.preventDefault();
          showToast('Screenshot blocked');
        }
        
        // Escape for panic
        if (e.key === 'Escape') {
          escapeCount++;
          clearTimeout(escapeTimer);
          escapeTimer = setTimeout(() => escapeCount = 0, 800);
          if (escapeCount >= 3) {
            triggerPanic();
          }
        }
        
        // Cmd/Ctrl+F for search
        if ((e.metaKey || e.ctrlKey) && e.key === 'f') {
          e.preventDefault();
          toggleSearch();
        }
      });
      
      // License key formatter
      document.getElementById('licenseKeyInput').addEventListener('input', (e) => {
        let value = e.target.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
        if (value.length > 4) value = value.slice(0, 4) + '-' + value.slice(4);
        if (value.length > 9) value = value.slice(0, 9) + '-' + value.slice(9);
        if (value.length > 14) value = value.slice(0, 14) + '-' + value.slice(14);
        e.target.value = value.slice(0, 19);
      });
      
      // Context menu
      document.getElementById('chatContainer').addEventListener('contextmenu', (e) => {
        e.preventDefault();
        showContextMenu(e.clientX, e.clientY);
      });
      
      document.addEventListener('click', () => {
        document.getElementById('contextMenu').classList.remove('visible');
      });
    }
    
    async function sendMessage() {
      const input = document.getElementById('messageInput');
      const content = input.value.trim();
      
      if (!content) return;
      
      if (!conn || !conn.open) {
        showToast('Not connected to any peer');
        return;
      }
      
      // Check message limit
      if (!isPaid && messageCount >= freeMessages) {
        showOverlay('paywall');
        return;
      }
      
      let messageContent = content;
      let encrypted = false;
      
      // Encrypt if key exists
      if (encryptionKey) {
        messageContent = await encryptMessage(content, encryptionKey);
        encrypted = true;
      }
      
      const msgId = 'msg-' + Date.now();
      const timestamp = new Date().toISOString();
      
      const messageData = {
        type: 'MSG',
        id: msgId,
        content: messageContent,
        encrypted: encrypted,
        timestamp: timestamp
      };
      
      conn.send(messageData);
      addMessage(content, 'you', msgId, timestamp, encrypted);
      
      input.value = '';
      input.style.height = 'auto';
      document.getElementById('sendBtn').disabled = true;
      
      // Increment message count
      if (!isPaid) {
        messageCount++;
        localStorage.setItem('postal_message_count', messageCount);
        updateFreeCount();
      }
      
      // Auto-destruct if set
      if (autoDestructTimer > 0) {
        setTimeout(() => {
          deleteMessage(msgId);
          conn.send({ type: 'CMD_PURGE', msgId: msgId });
        }, autoDestructTimer * 1000);
      }
      
      // Stop typing indicator
      if (conn && conn.open) {
        conn.send({ type: 'CMD_TYPING_STOP' });
      }
    }
    
    function addMessage(content, sender, id, timestamp, encrypted = false) {
      const container = document.getElementById('chatContainer');
      const time = new Date(timestamp || Date.now()).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      
      const msgEl = document.createElement('div');
      msgEl.className = `message ${sender}`;
      msgEl.id = id;
      msgEl.dataset.timestamp = timestamp;
      
      let encryptedIcon = encrypted ? '🔒' : '';
      
      msgEl.innerHTML = `
        <div class="msg-header">
          <span class="msg-name">${sender === 'you' ? 'YOU' : 'PEER'}</span>
          ${encrypted ? '<span class="msg-encrypted">' + encryptedIcon + '</span>' : ''}
        </div>
        <div class="msg-text">${escapeHtml(content)}</div>
        <div class="msg-footer">
          <span class="msg-time">${time}</span>
          ${sender === 'you' ? '<span class="msg-status">✓</span>' : ''}
        </div>
        <div class="reaction-bar">
          <button class="reaction-btn" onclick="sendReaction('${id}', '😂')">😂</button>
          <button class="reaction-btn" onclick="sendReaction('${id}', '❤️')">❤️</button>
          <button class="reaction-btn" onclick="sendReaction('${id}', '👍')">👍</button>
          <button class="reaction-btn" onclick="sendReaction('${id}', '😮')">😮</button>
          <button class="reaction-btn" onclick="sendReaction('${id}', '😢')">😢</button>
        </div>
      `;
      
      container.appendChild(msgEl);
      container.scrollTop = container.scrollHeight;
    }
    
    function addSystemMessage(content) {
      const container = document.getElementById('chatContainer');
      const msgEl = document.createElement('div');
      msgEl.className = 'message system';
      msgEl.innerHTML = `<div class="msg-text">${escapeHtml(content)}</div>`;
      container.appendChild(msgEl);
      container.scrollTop = container.scrollHeight;
    }
    
    function handleVoiceNote(data) {
      const container = document.getElementById('chatContainer');
      const msgEl = document.createElement('div');
      msgEl.className = 'message peer';
      
      msgEl.innerHTML = `
        <div class="voice-note">
          <button class="voice-play-btn" onclick="playVoiceNote(this, '${data.data}')">▶</button>
          <div class="voice-waveform">
            ${Array(20).fill('<div class="waveform-bar" style="height:' + Math.random() * 20 + 'px"></div>').join('')}
          </div>
          <span class="voice-duration">${Math.floor(data.duration / 60)}:${String(data.duration % 60).padStart(2, '0')}</span>
        </div>
        <audio src="${data.data}" style="display:none"></audio>
      `;
      
      container.appendChild(msgEl);
      container.scrollTop = container.scrollHeight;
      notifyUser('Voice Note', 'New voice message received');
    }
    
    function playVoiceNote(btn, dataUrl) {
      const audio = btn.parentElement.querySelector('audio');
      if (audio.paused) {
        audio.src = dataUrl;
        audio.play();
        btn.textContent = '⏸';
      } else {
        audio.pause();
        btn.textContent = '▶';
      }
    }
    
    function handleFile(data) {
      const container = document.getElementById('chatContainer');
      const msgEl = document.createElement('div');
      msgEl.className = 'message peer';
      
      const icon = getFileIcon(data.fileType);
      const size = formatFileSize(data.fileSize);
      
      msgEl.innerHTML = `
        <div class="file-message">
          <span class="file-icon">${icon}</span>
          <div class="file-info">
            <div class="file-name">${escapeHtml(data.fileName)}</div>
            <div class="file-size">${size}</div>
          </div>
          <button class="file-download" onclick="downloadFile('${data.data}', '${data.fileName}')">DOWNLOAD</button>
        </div>
      `;
      
      container.appendChild(msgEl);
      container.scrollTop = container.scrollHeight;
    }
    
    function getFileIcon(type) {
      if (type.startsWith('image/')) return '🖼️';
      if (type.startsWith('audio/')) return '🎵';
      if (type.startsWith('video/')) return '🎬';
      if (type.includes('pdf')) return '📄';
      if (type.includes('zip') || type.includes('rar')) return '📦';
      return '📄';
    }
    
    function formatFileSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    }
    
    function downloadFile(dataUrl, fileName) {
      const a = document.createElement('a');
      a.href = dataUrl;
      a.download = fileName;
      a.click();
    }
    
    async function toggleVoiceRecording() {
      const btn = document.getElementById('voiceBtn');
      
      if (!isRecording) {
        try {
          const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
          mediaRecorder = new MediaRecorder(stream);
          audioChunks = [];
          recordingDuration = 0;
          
          mediaRecorder.ondataavailable = (e) => audioChunks.push(e.data);
          
          mediaRecorder.onstop = async () => {
            const blob = new Blob(audioChunks, { type: 'audio/webm' });
            const reader = new FileReader();
            reader.onload = (e) => {
              if (conn && conn.open) {
                conn.send({
                  type: 'VOICE',
                  data: e.target.result,
                  duration: recordingDuration
                });
                addSystemMessage('Voice note sent (' + recordingDuration + 's)');
              }
            };
            reader.readAsDataURL(blob);
            stream.getTracks().forEach(t => t.stop());
          };
          
          mediaRecorder.start();
          btn.classList.add('recording');
          btn.textContent = '⏹';
          isRecording = true;
          
          // Track duration
          const durationInterval = setInterval(() => {
            if (!isRecording) {
              clearInterval(durationInterval);
              return;
            }
            recordingDuration++;
            if (recordingDuration >= 300) { // 5 min max
              toggleVoiceRecording();
            }
          }, 1000);
          
        } catch (err) {
          showToast('Microphone access denied');
        }
      } else {
        mediaRecorder.stop();
        btn.classList.remove('recording');
        btn.textContent = '🎤';
        isRecording = false;
      }
    }
    
    function handleFileSelect(e) {
      const file = e.target.files[0];
      if (!file) return;
      
      if (file.size > 10 * 1024 * 1024) {
        showToast('File too large (max 10MB)');
        return;
      }
      
      const reader = new FileReader();
      reader.onload = (e) => {
        if (conn && conn.open) {
          conn.send({
            type: 'FILE',
            data: e.target.result,
            fileName: file.name,
            fileType: file.type,
            fileSize: file.size
          });
          addSystemMessage('File sent: ' + file.name);
        }
      };
      reader.readAsDataURL(file);
      e.target.value = '';
    }
    
    // Encryption functions
    async function setupEncryption(password) {
      try {
        encryptionKey = await deriveKey(password, 'postal-salt-' + myPeerId);
        document.getElementById('encryptionStatus').innerHTML = '🔒 ENCRYPTED';
        document.getElementById('encryptionStatus').className = 'status-item encrypted';
        document.getElementById('infoEncryption').textContent = 'AES-256-GCM';
        showToast('Session encrypted');
      } catch (err) {
        console.error('Encryption setup failed:', err);
        showToast('Encryption setup failed');
      }
    }
    
    async function deriveKey(password, salt) {
      const enc = new TextEncoder();
      const keyMaterial = await crypto.subtle.importKey(
        "raw", enc.encode(password), "PBKDF2", false, ["deriveKey"]
      );
      return crypto.subtle.deriveKey(
        { name: "PBKDF2", salt: enc.encode(salt), iterations: 100000, hash: "SHA-256" },
        keyMaterial,
        { name: "AES-GCM", length: 256 },
        false,
        ["encrypt", "decrypt"]
      );
    }
    
    async function encryptMessage(text, key) {
      const iv = crypto.getRandomValues(new Uint8Array(12));
      const encoded = new TextEncoder().encode(text);
      const ciphertext = await crypto.subtle.encrypt({ name: "AES-GCM", iv }, key, encoded);
      const combined = new Uint8Array(iv.byteLength + ciphertext.byteLength);
      combined.set(iv, 0);
      combined.set(new Uint8Array(ciphertext), iv.byteLength);
      return btoa(String.fromCharCode(...combined));
    }
    
    async function decryptMessage(b64, key) {
      try {
        const combined = Uint8Array.from(atob(b64), c => c.charCodeAt(0));
        const iv = combined.slice(0, 12);
        const ciphertext = combined.slice(12);
        const decoded = await crypto.subtle.decrypt({ name: "AES-GCM", iv }, key, ciphertext);
        return new TextDecoder().decode(decoded);
      } catch (err) {
        console.error('Decryption failed:', err);
        return '[Decryption failed]';
      }
    }
    
    // AES Password handler
    document.getElementById('aesPassword').addEventListener('change', async (e) => {
      const password = e.target.value;
      if (password) {
        await setupEncryption(password);
      } else {
        encryptionKey = null;
        document.getElementById('encryptionStatus').innerHTML = '🔓 UNENCRYPTED';
        document.getElementById('encryptionStatus').className = 'status-item unencrypted';
        document.getElementById('infoEncryption').textContent = 'None';
      }
    });
    
    // UI Functions
    function showOverlay(type) {
      const overlayMap = {
        'terms': 'termsOverlay',
        'connect': 'connectOverlay',
        'paywall': 'paywallOverlay',
        'settings': 'settingsOverlay',
        'qr': 'qrOverlay',
        'group': 'groupOverlay',
        'burn': 'burnOverlay'
      };
      
      const overlayId = overlayMap[type];
      if (overlayId) {
        document.getElementById(overlayId).classList.add('visible');
      }
    }
    
    function hideOverlay(type) {
      const overlayMap = {
        'terms': 'termsOverlay',
        'connect': 'connectOverlay',
        'paywall': 'paywallOverlay',
        'settings': 'settingsOverlay',
        'qr': 'qrOverlay',
        'group': 'groupOverlay',
        'burn': 'burnOverlay'
      };
      
      const overlayId = overlayMap[type];
      if (overlayId) {
        document.getElementById(overlayId).classList.remove('visible');
      }
    }
    
    function checkTermsAccept() {
      const agree1 = document.getElementById('agreeLiability').checked;
      const agree2 = document.getElementById('agreeAge').checked;
      document.getElementById('acceptTermsBtn').disabled = !(agree1 && agree2);
    }
    
    function acceptTerms() {
      sessionStorage.setItem('postal_terms_accepted', 'true');
      hideOverlay('terms');
      showToast('Session initialized');
    }
    
    function switchConnectTab(tab) {
      document.querySelectorAll('.connect-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      
      if (tab === 'direct') {
        document.querySelector('.connect-tab:first-child').classList.add('active');
        document.getElementById('directTab').classList.add('active');
      } else {
        document.querySelector('.connect-tab:last-child').classList.add('active');
        document.getElementById('boardTab').classList.add('active');
        loadBoardPeers();
      }
    }
    
    function loadBoardPeers() {
      const peerList = document.getElementById('boardPeerList');
      const peers = JSON.parse(localStorage.getItem('postal_board_peers') || '[]');
      
      if (peers.length === 0) {
        peerList.innerHTML = '<p style="font-size:11px;opacity:0.6;text-align:center;padding:20px;">No peers on the board. Be the first!</p>';
        return;
      }
      
      peerList.innerHTML = peers.map(p => `
        <div class="peer-item">
          <span class="peer-item-name">${escapeHtml(p.name)}</span>
          <button class="peer-item-connect" onclick="connectFromBoard('${p.id}')">CONNECT</button>
        </div>
      `).join('');
    }
    
    function postToBoard() {
      const name = document.getElementById('displayName').value.trim() || 'Anonymous';
      const peers = JSON.parse(localStorage.getItem('postal_board_peers') || '[]');
      
      // Remove old entries
      const now = Date.now();
      const filtered = peers.filter(p => now - p.timestamp < 5 * 60 * 1000);
      
      filtered.push({
        id: myPeerId,
        name: name,
        timestamp: now
      });
      
      localStorage.setItem('postal_board_peers', JSON.stringify(filtered));
      showToast('Posted to board');
      loadBoardPeers();
    }
    
    function connectFromBoard(peerId) {
      document.getElementById('peerIdInput').value = peerId;
      switchConnectTab('direct');
      connectToPeer();
    }
    
    function setTheme(theme) {
      document.body.setAttribute('data-theme', theme);
      localStorage.setItem('postal_theme', theme);
      
      const themeNames = { 'void': 'VOID', 'neon': 'NEON', 'ghost': 'GHOST', 'paper': 'PAPER' };
      document.getElementById('themeName').textContent = themeNames[theme];
      document.getElementById('mobileThemeName').textContent = themeNames[theme];
      
      document.querySelectorAll('.theme-pill').forEach(p => {
        p.classList.toggle('active', p.dataset.theme === theme);
      });
    }
    
    function toggleVanish() {
      vanishMode = !vanishMode;
      localStorage.setItem('postal_vanish', vanishMode);
      
      document.getElementById('vanishToggle').classList.toggle('active', vanishMode);
      document.getElementById('settingsVanishToggle').classList.toggle('active', vanishMode);
      
      showToast(vanishMode ? 'Vanish mode ON' : 'Vanish mode OFF');
    }
    
    function setAutoDestruct(value) {
      autoDestructTimer = parseInt(value);
      if (value !== '0') {
        showToast('Auto-destruct: ' + value + 's');
      }
    }
    
    function toggleSound() {
      soundEnabled = !soundEnabled;
      localStorage.setItem('postal_sound', soundEnabled);
      document.getElementById('soundToggle').classList.toggle('active', soundEnabled);
    }
    
    function toggleSearch() {
      const searchBar = document.getElementById('searchBar');
      searchBar.classList.toggle('visible');
      if (searchBar.classList.contains('visible')) {
        document.getElementById('searchInput').focus();
      }
    }
    
    document.getElementById('searchInput').addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      document.querySelectorAll('.message .msg-text').forEach(m => {
        const text = m.textContent.toLowerCase();
        if (query && text.includes(query)) {
          m.innerHTML = m.textContent.replace(
            new RegExp(`(${query})`, 'gi'),
            '<mark style="background:var(--accent);color:#000">$1</mark>'
          );
        } else {
          m.innerHTML = m.textContent;
        }
      });
    });
    
    function updateStatus(status) {
      const statusDot = document.getElementById('statusDot');
      const headerDot = document.getElementById('headerStatusDot');
      const statusText = document.getElementById('statusText');
      
      statusDot.className = 'status-dot';
      headerDot.className = 'status-dot';
      
      switch (status) {
        case 'connecting':
          statusDot.classList.add('connecting');
          headerDot.classList.add('connecting');
          statusText.textContent = 'CONNECTING';
          document.getElementById('infoStatus').textContent = 'Connecting...';
          break;
        case 'connected':
          statusDot.classList.add('connected');
          headerDot.classList.add('connected');
          statusText.textContent = 'TUNNEL ACTIVE';
          document.getElementById('infoStatus').textContent = 'Connected';
          break;
        default:
          statusText.textContent = 'OFFLINE';
          document.getElementById('infoStatus').textContent = 'Offline';
      }
    }
    
    function updateNodeIdDisplay() {
      const shortId = myPeerId ? myPeerId.substring(0, 16) + '...' : 'INITIALIZING...';
      document.getElementById('nodeId').textContent = 'NODE: ' + shortId;
      document.getElementById('myPeerIdDisplay').textContent = myPeerId || 'Loading...';
      document.getElementById('infoPeerId').textContent = myPeerId ? myPeerId.substring(0, 12) + '...' : '—';
    }
    
    function updateFreeCount() {
      const remaining = freeMessages - messageCount;
      document.getElementById('freeCount').textContent = `FREE: ${remaining}/${freeMessages} MESSAGES`;
      document.getElementById('infoMessagesLeft').textContent = remaining;
      
      if (remaining <= 0 && !isPaid) {
        document.getElementById('upgradeBtn').style.display = 'block';
      }
    }
    
    function updatePremiumUI() {
      if (isPaid) {
        document.getElementById('premiumBadge').style.display = 'inline-flex';
        document.getElementById('upgradeBtn').style.display = 'none';
        document.getElementById('freeCount').style.display = 'none';
        document.getElementById('premiumStatus').textContent = 'PREMIUM';
        document.getElementById('infoPlan').textContent = 'Premium';
        document.getElementById('infoGroupChat').textContent = '✅ Available';
        document.getElementById('infoBurnNotes').textContent = '✅ Available';
        document.getElementById('burnNoteBtn').style.opacity = '1';
      } else {
        document.getElementById('premiumBadge').style.display = 'none';
        document.getElementById('upgradeBtn').style.display = 'block';
        document.getElementById('freeCount').style.display = 'block';
        document.getElementById('premiumStatus').textContent = 'FREE TIER';
        document.getElementById('infoPlan').textContent = 'Free';
        document.getElementById('infoGroupChat').textContent = '🔒 Premium';
        document.getElementById('infoBurnNotes').textContent = '🔒 Premium';
        document.getElementById('burnNoteBtn').style.opacity = '0.5';
        updateFreeCount();
      }
    }
    
    function generateQRCode() {
      const inviteUrl = window.location.origin + '?join=' + myPeerId;
      
      // Mini QR
      const miniContainer = document.getElementById('qr-container-mini');
      miniContainer.innerHTML = '';
      new QRCode(miniContainer, {
        text: inviteUrl,
        width: 120,
        height: 120,
        colorDark: '#6C63FF',
        colorLight: '#000000',
        correctLevel: QRCode.CorrectLevel.H
      });
      
      // Main QR (generate when overlay opens)
      const mainContainer = document.getElementById('qrMainContainer');
      mainContainer.innerHTML = '';
      new QRCode(mainContainer, {
        text: inviteUrl,
        width: 220,
        height: 220,
        colorDark: '#6C63FF',
        colorLight: '#ffffff',
        correctLevel: QRCode.CorrectLevel.H
      });
    }
    
    function copyPeerId() {
      navigator.clipboard.writeText(myPeerId);
      showToast('Peer ID copied');
    }
    
    function copyInviteLink() {
      const link = window.location.origin + '?join=' + myPeerId;
      navigator.clipboard.writeText(link);
      showToast('Invite link copied');
    }
    
    function showTypingIndicator() {
      document.getElementById('typingIndicator').classList.add('visible');
    }
    
    function hideTypingIndicator() {
      document.getElementById('typingIndicator').classList.remove('visible');
    }
    
    function markMessageSeen(msgId) {
      const msg = document.getElementById(msgId);
      if (msg) {
        const status = msg.querySelector('.msg-status');
        if (status) status.textContent = '✓✓';
      }
    }
    
    function deleteMessage(msgId) {
      const msg = document.getElementById(msgId);
      if (msg) msg.remove();
    }
    
    function sendReaction(msgId, emoji) {
      if (conn && conn.open) {
        conn.send({ type: 'CMD_REACT', msgId: msgId, emoji: emoji });
        addReaction(msgId, emoji);
      }
    }
    
    function addReaction(msgId, emoji) {
      const msg = document.getElementById(msgId);
      if (msg) {
        let reactions = msg.querySelector('.msg-reactions');
        if (!reactions) {
          reactions = document.createElement('div');
          reactions.className = 'msg-reactions';
          msg.appendChild(reactions);
        }
        const reaction = document.createElement('span');
        reaction.className = 'msg-reaction';
        reaction.textContent = emoji;
        reactions.appendChild(reaction);
      }
    }
    
    function purgeChat() {
      document.getElementById('chatContainer').innerHTML = '';
      addSystemMessage('Chat purged by peer');
    }
    
    function triggerPanic() {
      const panicUrl = document.getElementById('panicUrl').value || 'https://google.com';
      
      // Show fake Google screen
      document.getElementById('panicOverlay').classList.add('visible');
      
      // Wipe data
      ['postal_paid', 'postal_license', 'postal_plan', 'postal_message_count', 'postal_theme'].forEach(k => {
        localStorage.removeItem(k);
      });
      document.getElementById('chatContainer').innerHTML = '';
      
      if (conn && conn.open) conn.close();
      
      // Countdown and redirect
      let countdown = 3;
      const countdownEl = document.getElementById('panicCountdown');
      const interval = setInterval(() => {
        countdown--;
        countdownEl.textContent = `REDIRECTING IN ${countdown}...`;
        if (countdown <= 0) {
          clearInterval(interval);
          window.location.href = panicUrl;
        }
      }, 1000);
    }
    
    function showContextMenu(x, y) {
      const menu = document.getElementById('contextMenu');
      menu.style.left = x + 'px';
      menu.style.top = y + 'px';
      menu.classList.add('visible');
    }
    
    // Payment functions
    function selectPlan(plan) {
      selectedPlan = plan;
      document.getElementById('monthlyPlan').classList.toggle('selected', plan === 'monthly');
      document.getElementById('lifetimePlan').classList.toggle('selected', plan === 'lifetime');
    }
    
    async function initPayment() {
      showToast('Loading payment...');
      
      try {
        const response = await fetch('/api/create-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ plan: selectedPlan })
        });
        
        const data = await response.json();
        
        if (!data.success) {
          showToast('Payment init failed');
          return;
        }
        
        const options = {
          key: data.key_id,
          amount: data.amount,
          currency: data.currency,
          order_id: data.order_id,
          name: 'Postal Premium',
          description: data.plan_name + ' plan',
          handler: async (response) => {
            await verifyPayment(response, selectedPlan);
          },
          theme: { color: '#6C63FF' }
        };
        
        const rzp = new Razorpay(options);
        rzp.open();
        
      } catch (err) {
        console.error('Payment error:', err);
        showToast('Payment failed');
      }
    }
    
    async function verifyPayment(response, plan) {
      try {
        const res = await fetch('/api/verify-payment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            razorpay_order_id: response.razorpay_order_id,
            razorpay_payment_id: response.razorpay_payment_id,
            razorpay_signature: response.razorpay_signature,
            plan: plan
          })
        });
        
        const data = await res.json();
        
        if (data.success) {
          localStorage.setItem('postal_paid', 'true');
          localStorage.setItem('postal_license', data.license_key);
          localStorage.setItem('postal_plan', plan);
          isPaid = true;
          updatePremiumUI();
          hideOverlay('paywall');
          showToast('Premium activated!');
        } else {
          showToast('Payment verification failed');
        }
      } catch (err) {
        console.error('Verification error:', err);
        showToast('Verification failed');
      }
    }
    
    async function activateLicense() {
      const key = document.getElementById('licenseKeyInput').value.trim();
      
      if (!key) {
        showToast('Enter a license key');
        return;
      }
      
      try {
        const res = await fetch('/api/verify-license', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ license_key: key })
        });
        
        const data = await res.json();
        
        if (data.valid) {
          localStorage.setItem('postal_paid', 'true');
          localStorage.setItem('postal_license', key);
          localStorage.setItem('postal_plan', data.plan);
          isPaid = true;
          updatePremiumUI();
          hideOverlay('paywall');
          showToast('License activated!');
        } else {
          showToast('Invalid license key');
        }
      } catch (err) {
        console.error('License error:', err);
        showToast('Verification failed');
      }
    }
    
    async function applyReferral() {
      const code = document.getElementById('referralInput').value.trim();
      
      if (!code) {
        showToast('Enter a referral code');
        return;
      }
      
      try {
        const res = await fetch('/api/use-referral', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code: code })
        });
        
        const data = await res.json();
        
        if (data.valid) {
          freeMessages += data.bonus_messages;
          localStorage.setItem('postal_free_messages', freeMessages);
          updateFreeCount();
          showToast('+' + data.bonus_messages + ' free messages!');
          document.getElementById('referralInput').value = '';
        } else {
          showToast('Invalid referral code');
        }
      } catch (err) {
        console.error('Referral error:', err);
        showToast('Failed to apply referral');
      }
    }
    
    // Burn Note functions
    async function createBurnNote() {
      const content = document.getElementById('burnNoteContent').value.trim();
      const hint = document.getElementById('burnNoteHint').value.trim();
      
      if (!content) {
        showToast('Enter note content');
        return;
      }
      
      if (!isPaid) {
        showOverlay('paywall');
        return;
      }
      
      try {
        const res = await fetch('/api/create-note', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ content: content, password_hint: hint })
        });
        
        const data = await res.json();
        
        if (data.success) {
          document.getElementById('burnNoteUrl').textContent = data.url;
          document.getElementById('burnNoteResult').style.display = 'block';
          showToast('Burn note created!');
        } else {
          showToast('Failed to create note');
        }
      } catch (err) {
        console.error('Burn note error:', err);
        showToast('Failed to create note');
      }
    }
    
    function copyBurnNoteUrl() {
      const url = document.getElementById('burnNoteUrl').textContent;
      navigator.clipboard.writeText(url);
      showToast('Link copied');
    }
    
    // Export functions
    function exportChat(format) {
      const messages = [];
      document.querySelectorAll('.message').forEach(msg => {
        const sender = msg.classList.contains('you') ? 'You' : (msg.classList.contains('peer') ? 'Peer' : 'System');
        const text = msg.querySelector('.msg-text')?.textContent || '';
        const time = msg.querySelector('.msg-time')?.textContent || '';
        messages.push({ sender, text, time });
      });
      
      if (format === 'json') {
        const blob = new Blob([JSON.stringify(messages, null, 2)], { type: 'application/json' });
        downloadBlob(blob, 'postal-chat-' + Date.now() + '.json');
      } else {
        const text = messages.map(m => `[${m.time}] ${m.sender}: ${m.text}`).join('\n');
        const blob = new Blob([text], { type: 'text/plain' });
        downloadBlob(blob, 'postal-chat-' + Date.now() + '.txt');
      }
      
      showToast('Chat exported');
    }
    
    function downloadBlob(blob, filename) {
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = filename;
      a.click();
    }
    
    function clearHistory() {
      if (confirm('Clear all chat history?')) {
        document.getElementById('chatContainer').innerHTML = '';
        addSystemMessage('Chat history cleared');
        showToast('History cleared');
      }
    }
    
    // Group Chat functions
    function handlePeerList(peerIds) {
      if (!isPaid) return;
      
      peerIds.forEach(id => {
        if (id !== myPeerId && !peers[id]) {
          const c = peer.connect(id, { reliable: true });
          peers[id] = c;
          setupConnection(c);
        }
      });
      
      updateGroupUI();
    }
    
    function updateGroupUI() {
      const memberCount = Object.keys(peers).length + 1;
      document.getElementById('memberCount').textContent = memberCount + ' members';
      document.getElementById('groupBadge').textContent = memberCount;
      document.getElementById('groupBadge').style.display = 'inline';
      
      const membersList = document.getElementById('groupMembers');
      membersList.innerHTML = `
        <div class="group-member">
          <span class="group-member-id">${myPeerId.substring(0, 12)}... (You)</span>
          <span class="group-member-status active">Active</span>
        </div>
      `;
      
      Object.keys(peers).forEach(id => {
        const status = peers[id].open ? 'active' : 'connecting';
        membersList.innerHTML += `
          <div class="group-member">
            <span class="group-member-id">${id.substring(0, 12)}...</span>
            <span class="group-member-status ${status}">${status.charAt(0).toUpperCase() + status.slice(1)}</span>
          </div>
        `;
      });
    }
    
    function leaveGroup() {
      Object.values(peers).forEach(c => {
        if (c.open) c.close();
      });
      peers = {};
      updateGroupUI();
      hideOverlay('group');
      addSystemMessage('Left group chat');
    }
    
    // Utility functions
    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
    
    function showToast(message) {
      const toast = document.getElementById('toast');
      toast.textContent = message;
      toast.classList.add('visible');
      setTimeout(() => toast.classList.remove('visible'), 2800);
    }
    
    function notifyUser(title, body) {
      if (soundEnabled) {
        // Play notification sound
        try {
          const audio = new Audio('data:audio/wav;base64,UklGRnoGAABXQVZFZm10IBAAAAABAAEAQB8AAEAfAAABAAgAZGF0YQoGAACBhYqFbF1fdJivrJBhNjVgodDbsGk' + 'A'.repeat(100));
          audio.volume = 0.5;
          audio.play().catch(() => {});
        } catch (e) {}
      }
      
      if ('Notification' in window && Notification.permission === 'granted') {
        new Notification(title, { body, icon: '/icons/icon-192.png' });
      }
    }
    
    function checkUrlParams() {
      const params = new URLSearchParams(window.location.search);
      const joinId = params.get('join');
      
      if (joinId) {
        setTimeout(() => {
          document.getElementById('peerIdInput').value = joinId;
          showOverlay('connect');
        }, 1000);
      }
    }
    
    function registerServiceWorker() {
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('sw.js')
          .then(() => console.log('SW registered'))
          .catch(err => console.error('SW registration failed:', err));
      }
      
      // Request notification permission
      if ('Notification' in window && Notification.permission === 'default') {
        Notification.requestPermission();
      }
    }
    
    // Public Board cleanup (remove expired entries)
    setInterval(() => {
      const peers = JSON.parse(localStorage.getItem('postal_board_peers') || '[]');
      const now = Date.now();
      const filtered = peers.filter(p => now - p.timestamp < 5 * 60 * 1000);
      if (filtered.length !== peers.length) {
        localStorage.setItem('postal_board_peers', JSON.stringify(filtered));
      }
    }, 60000);
  </script>
