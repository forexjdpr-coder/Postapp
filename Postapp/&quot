<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#6C63FF">
  <meta name="description" content="Postal - Private Secure Chat Space">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>Postal — Private Secure Chat Space</title>
  <link rel="manifest" href="manifest.json">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📮</text></svg>">
  <style>
    :root {
      --bg: #000000;
      --accent: #6C63FF;
      --text: #e8e6ff;
      --border: #1a1830;
      --card: #050510;
      --accent-rgb: 108, 99, 255;
    }
    
    [data-theme="neon"] {
      --bg: #000000;
      --accent: #00ff41;
      --text: #b8ffcc;
      --border: #0f2e14;
      --card: #030303;
      --accent-rgb: 0, 255, 65;
    }
    
    [data-theme="ghost"] {
      --bg: #000000;
      --accent: #ff2244;
      --text: #ffcccc;
      --border: #2e0f0f;
      --card: #040000;
      --accent-rgb: 255, 34, 68;
    }
    
    [data-theme="paper"] {
      --bg: #f5f5f0;
      --accent: #2563eb;
      --text: #1a1a2e;
      --border: #ddd;
      --card: #ffffff;
      --accent-rgb: 37, 99, 235;
    }
    
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      font-family: 'Courier New', monospace;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
      transition: all 0.2s ease;
    }
    
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 3px; }
    
    .app-container { display: flex; min-height: 100vh; width: 100%; }
    
    .sidebar {
      width: 240px;
      min-width: 240px;
      background: var(--card);
      border-right: 1px solid var(--border);
      padding: 20px;
      display: none;
      flex-direction: column;
      gap: 20px;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
    }
    
    @media (min-width: 1024px) { .sidebar { display: flex; } }
    @media (min-width: 1440px) { .sidebar { width: 260px; min-width: 260px; } }
    @media (min-width: 1920px) { .sidebar { width: 300px; min-width: 300px; } }
    
    .logo-section {
      text-align: center;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border);
    }
    
    .logo {
      font-size: clamp(24px, 4vw, 32px);
      font-weight: bold;
      color: var(--accent);
      letter-spacing: 4px;
    }
    
    .tagline {
      font-size: 10px;
      color: var(--text);
      opacity: 0.6;
      letter-spacing: 2px;
      margin-top: 4px;
    }
    
    .nav-section h4, .security-section h4, .theme-section h4, .status-section h4 {
      font-size: 10px;
      letter-spacing: 2px;
      opacity: 0.5;
      margin-bottom: 12px;
    }
    
    .nav-btn {
      width: 100%;
      padding: 12px 16px;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text);
      font-family: inherit;
      font-size: 12px;
      letter-spacing: 1px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
      transition: all 0.2s ease;
    }
    
    .nav-btn:hover {
      background: rgba(var(--accent-rgb), 0.1);
      border-color: var(--accent);
    }
    
    .nav-btn .badge {
      background: var(--accent);
      color: #000;
      font-size: 10px;
      padding: 2px 8px;
      border-radius: 10px;
      margin-left: auto;
    }
    
    .input-group { margin-bottom: 12px; }
    
    .input-group input {
      width: 100%;
      padding: 10px;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: inherit;
      font-size: 11px;
    }
    
    .input-group input:focus { outline: none; border-color: var(--accent); }
    
    .toggle-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 0;
    }
    
    .toggle-row span { font-size: 11px; letter-spacing: 1px; }
    
    .toggle {
      width: 44px;
      height: 24px;
      background: var(--border);
      border-radius: 12px;
      position: relative;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    
    .toggle.active { background: var(--accent); }
    
    .toggle::after {
      content: '';
      position: absolute;
      width: 18px;
      height: 18px;
      background: var(--text);
      border-radius: 50%;
      top: 3px;
      left: 3px;
      transition: all 0.2s ease;
    }
    
    .toggle.active::after { left: 23px; }
    
    .panic-btn {
      width: 100%;
      padding: 12px;
      background: #ff2244;
      border: none;
      color: #fff;
      font-family: inherit;
      font-size: 11px;
      letter-spacing: 2px;
      cursor: pointer;
      margin-top: 8px;
      transition: all 0.2s ease;
    }
    
    .panic-btn:hover { background: #ff4466; transform: scale(1.02); }
    
    .theme-pills { display: flex; gap: 6px; flex-wrap: wrap; }
    
    .theme-pill {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      border: 2px solid transparent;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    
    .theme-pill:hover, .theme-pill.active { border-color: var(--text); transform: scale(1.1); }
    .theme-pill[data-theme="void"] { background: #6C63FF; }
    .theme-pill[data-theme="neon"] { background: #00ff41; }
    .theme-pill[data-theme="ghost"] { background: #ff2244; }
    .theme-pill[data-theme="paper"] { background: #f5f5f0; border: 2px solid #ddd; }
    
    .theme-name { font-size: 10px; letter-spacing: 1px; margin-top: 8px; opacity: 0.7; }
    
    .auto-destruct-select {
      width: 100%;
      padding: 10px;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: inherit;
      font-size: 11px;
      cursor: pointer;
    }
    
    .auto-destruct-select:focus { outline: none; border-color: var(--accent); }
    
    .status-indicator { display: flex; align-items: center; gap: 8px; padding: 8px 0; }
    
    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #ff2244;
    }
    
    .status-dot.connecting { background: #ffaa00; animation: pulse 1s infinite; }
    .status-dot.connected { background: #00ff41; }
    
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
    
    .status-text { font-size: 10px; letter-spacing: 1px; }
    
    .node-id { font-size: 9px; opacity: 0.5; word-break: break-all; margin-top: 4px; }
    
    .premium-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      background: linear-gradient(135deg, var(--accent), #9d6bff);
      color: #000;
      font-size: 9px;
      font-weight: bold;
      padding: 4px 10px;
      border-radius: 12px;
      margin-top: 8px;
      letter-spacing: 1px;
    }
    
    .free-count { font-size: 10px; opacity: 0.7; margin-top: 8px; }
    
    .upgrade-btn {
      width: 100%;
      padding: 10px;
      background: transparent;
      border: 1px solid var(--accent);
      color: var(--accent);
      font-family: inherit;
      font-size: 10px;
      letter-spacing: 2px;
      cursor: pointer;
      margin-top: 10px;
      transition: all 0.2s ease;
    }
    
    .upgrade-btn:hover { background: var(--accent); color: #000; }
    
    .main-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      max-width: 680px;
      margin: 0 auto;
      width: 100%;
    }
    
    @media (min-width: 1024px) { .main-content { max-width: 680px; } }
    @media (min-width: 1440px) { .main-content { max-width: 780px; } }
    @media (min-width: 1920px) { .main-content { max-width: 900px; } }
    
    .chat-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 20px;
      background: var(--card);
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    
    .header-left { display: flex; align-items: center; gap: 12px; }
    
    .mobile-logo { font-size: 18px; font-weight: bold; color: var(--accent); letter-spacing: 2px; }
    @media (min-width: 1024px) { .mobile-logo { display: none; } }
    
    .connection-status { display: flex; align-items: center; gap: 8px; }
    .member-count { font-size: 11px; opacity: 0.7; letter-spacing: 1px; }
    .header-actions { display: flex; gap: 8px; }
    
    .header-btn {
      width: 36px;
      height: 36px;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      transition: all 0.2s ease;
    }
    
    .header-btn:hover { background: rgba(var(--accent-rgb), 0.1); border-color: var(--accent); }
    
    .mobile-theme-bar {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 10px;
      background: var(--card);
      border-bottom: 1px solid var(--border);
    }
    
    @media (min-width: 1024px) { .mobile-theme-bar { display: none; } }
    .mobile-theme-bar .theme-pill { width: 24px; height: 24px; }
    .mobile-theme-bar .theme-name { margin: 0; }
    
    .status-bar {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 8px;
      background: rgba(var(--accent-rgb), 0.05);
      border-bottom: 1px solid var(--border);
      font-size: 9px;
      letter-spacing: 1px;
      flex-wrap: wrap;
    }
    
    .status-item { display: flex; align-items: center; gap: 4px; opacity: 0.7; }
    .status-item.encrypted { color: #00ff41; }
    .status-item.unencrypted { color: #ff2244; }
    
    .chat-container {
      flex: 1;
      overflow-y: auto;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    
    .message {
      max-width: 85%;
      padding: 12px 16px;
      border-radius: 4px;
      position: relative;
      animation: fadeUp 0.3s ease;
    }
    
    @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    
    .message.you {
      align-self: flex-end;
      background: rgba(var(--accent-rgb), 0.08);
      border-right: 2px solid var(--accent);
    }
    
    .message.peer {
      align-self: flex-start;
      background: rgba(255, 255, 255, 0.04);
      border-left: 2px solid var(--text);
    }
    
    .message.system {
      align-self: center;
      background: rgba(var(--accent-rgb), 0.06);
      font-style: italic;
      font-size: 11px;
      opacity: 0.7;
      max-width: 90%;
      text-align: center;
    }
    
    .msg-header { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
    .msg-name { font-size: 10px; font-weight: bold; letter-spacing: 1px; }
    .message.you .msg-name { color: var(--accent); }
    .message.peer .msg-name { color: var(--text); }
    .msg-encrypted { font-size: 10px; }
    .msg-text { font-size: 13px; line-height: 1.5; word-break: break-word; }
    .msg-footer { display: flex; align-items: center; justify-content: flex-end; gap: 8px; margin-top: 6px; }
    .msg-time { font-size: 9px; opacity: 0.5; }
    .msg-status { font-size: 10px; color: var(--accent); }
    
    .msg-timer {
      position: absolute;
      top: 8px;
      right: 8px;
      width: 20px;
      height: 20px;
      border: 2px solid #ff2244;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 8px;
      color: #ff2244;
    }
    
    .reaction-bar {
      position: absolute;
      bottom: -30px;
      left: 50%;
      transform: translateX(-50%);
      display: none;
      gap: 4px;
      background: rgba(0, 0, 0, 0.98);
      border: 1px solid var(--accent);
      padding: 4px 8px;
      border-radius: 20px;
      z-index: 10;
    }
    
    .message:hover .reaction-bar { display: flex; }
    
    .reaction-btn {
      background: none;
      border: none;
      font-size: 14px;
      cursor: pointer;
      padding: 4px;
      transition: transform 0.2s ease;
    }
    
    .reaction-btn:hover { transform: scale(1.3); }
    
    .msg-reactions { display: flex; gap: 4px; margin-top: 6px; }
    .msg-reaction { background: rgba(var(--accent-rgb), 0.2); padding: 2px 8px; border-radius: 10px; font-size: 11px; }
    
    .voice-note {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 8px;
      background: rgba(var(--accent-rgb), 0.1);
      border-radius: 8px;
    }
    
    .voice-play-btn {
      width: 36px;
      height: 36px;
      background: var(--accent);
      border: none;
      border-radius: 50%;
      color: #000;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .voice-waveform { flex: 1; height: 30px; display: flex; align-items: center; gap: 2px; }
    
    .waveform-bar {
      width: 3px;
      background: var(--accent);
      border-radius: 2px;
      animation: waveform 0.5s ease infinite alternate;
    }
    
    @keyframes waveform { from { height: 10px; } to { height: 25px; } }
    .voice-duration { font-size: 11px; opacity: 0.7; }
    
    .file-message {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px;
      background: rgba(var(--accent-rgb), 0.1);
      border-radius: 8px;
    }
    
    .file-icon { font-size: 24px; }
    .file-info { flex: 1; }
    .file-name { font-size: 12px; word-break: break-all; }
    .file-size { font-size: 10px; opacity: 0.6; }
    
    .file-download {
      padding: 6px 12px;
      background: var(--accent);
      border: none;
      color: #000;
      font-family: inherit;
      font-size: 10px;
      cursor: pointer;
    }
    
    .input-area { padding: 16px; background: var(--card); border-top: 1px solid var(--border); }
    .input-container { display: flex; gap: 8px; align-items: flex-end; }
    .input-actions { display: flex; gap: 4px; }
    
    .input-action-btn {
      width: 36px;
      height: 36px;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      transition: all 0.2s ease;
    }
    
    .input-action-btn:hover { background: rgba(var(--accent-rgb), 0.1); border-color: var(--accent); }
    .input-action-btn.recording { background: #ff2244; border-color: #ff2244; animation: pulse 1s infinite; }
    
    .message-input {
      flex: 1;
      min-height: 40px;
      max-height: 120px;
      padding: 10px 14px;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: inherit;
      font-size: 13px;
      resize: none;
    }
    
    .message-input:focus { outline: none; border-color: var(--accent); }
    .message-input::placeholder { opacity: 0.5; }
    
    .send-btn {
      width: 40px;
      height: 40px;
      background: var(--accent);
      border: none;
      color: #000;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      transition: all 0.2s ease;
    }
    
    .send-btn:hover { transform: scale(1.05); }
    .send-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    
    .info-panel {
      width: 260px;
      min-width: 260px;
      background: var(--card);
      border-left: 1px solid var(--border);
      padding: 20px;
      display: none;
      flex-direction: column;
      gap: 20px;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
    }
    
    @media (min-width: 1440px) { .info-panel { display: flex; } }
    @media (min-width: 1920px) { .info-panel { width: 300px; min-width: 300px; } }
    
    .info-section h4 { font-size: 10px; letter-spacing: 2px; opacity: 0.5; margin-bottom: 12px; }
    
    .info-item {
      display: flex;
      justify-content: space-between;
      padding: 8px 0;
      border-bottom: 1px solid var(--border);
      font-size: 11px;
    }
    
    .info-item span:first-child { opacity: 0.6; }
    
    .mini-qr { text-align: center; padding: 16px; background: var(--bg); border: 1px solid var(--border); }
    .mini-qr #qr-container-mini { display: inline-block; }
    
    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.98);
      border: 2px solid var(--accent);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      padding: 20px;
      overflow-y: auto;
    }
    
    .overlay.visible { display: flex; }
    
    .modal {
      background: var(--card);
      border: 1px solid var(--accent);
      padding: 30px;
      max-width: 480px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
    }
    
    .modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
    .modal-title { font-size: 16px; letter-spacing: 2px; color: var(--accent); }
    
    .modal-close {
      width: 32px;
      height: 32px;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text);
      cursor: pointer;
      font-size: 18px;
    }
    
    .modal-close:hover { border-color: var(--accent); }
    
    .terms-content {
      max-height: 300px;
      overflow-y: auto;
      font-size: 12px;
      line-height: 1.8;
      margin-bottom: 20px;
      padding: 16px;
      background: var(--bg);
      border: 1px solid var(--border);
    }
    
    .checkbox-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
    .checkbox-row input { width: 18px; height: 18px; accent-color: var(--accent); }
    .checkbox-row label { font-size: 12px; cursor: pointer; }
    
    .accept-btn {
      width: 100%;
      padding: 14px;
      background: var(--accent);
      border: none;
      color: #000;
      font-family: inherit;
      font-size: 12px;
      letter-spacing: 2px;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    
    .accept-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .accept-btn:not(:disabled):hover { transform: scale(1.02); }
    
    .connect-tabs { display: flex; gap: 4px; margin-bottom: 20px; }
    
    .connect-tab {
      flex: 1;
      padding: 12px;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text);
      font-family: inherit;
      font-size: 11px;
      letter-spacing: 1px;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    
    .connect-tab.active { background: var(--accent); color: #000; border-color: var(--accent); }
    .tab-content { display: none; }
    .tab-content.active { display: block; }
    
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 10px; letter-spacing: 1px; opacity: 0.6; margin-bottom: 8px; }
    
    .form-group input {
      width: 100%;
      padding: 12px;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: inherit;
      font-size: 13px;
    }
    
    .form-group input:focus { outline: none; border-color: var(--accent); }
    
    .connect-btn {
      width: 100%;
      padding: 14px;
      background: var(--accent);
      border: none;
      color: #000;
      font-family: inherit;
      font-size: 12px;
      letter-spacing: 2px;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    
    .connect-btn:hover { transform: scale(1.02); }
    
    .peer-list { margin-top: 16px; max-height: 200px; overflow-y: auto; }
    
    .peer-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px;
      background: var(--bg);
      border: 1px solid var(--border);
      margin-bottom: 8px;
    }
    
    .peer-item-name { font-size: 12px; }
    
    .peer-item-connect {
      padding: 6px 12px;
      background: var(--accent);
      border: none;
      color: #000;
      font-family: inherit;
      font-size: 10px;
      cursor: pointer;
    }
    
    .plan-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
    
    .plan-card {
      padding: 16px;
      background: var(--bg);
      border: 2px solid var(--border);
      cursor: pointer;
      transition: all 0.2s ease;
      position: relative;
    }
    
    .plan-card.selected { border-color: var(--accent); }
    
    .plan-card.best-value::before {
      content: 'BEST VALUE';
      position: absolute;
      top: -10px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--accent);
      color: #000;
      font-size: 8px;
      padding: 2px 8px;
      letter-spacing: 1px;
    }
    
    .plan-name { font-size: 12px; letter-spacing: 1px; margin-bottom: 4px; }
    .plan-price { font-size: 20px; font-weight: bold; color: var(--accent); }
    
    .razorpay-btn {
      width: 100%;
